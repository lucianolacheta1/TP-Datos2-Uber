# Plantilla del archivo .env — copialo a .env (sin .example) y completá los valores.
# El .env real NO se commitea (está en .gitignore).

# ---- 1. PostgreSQL (Neon) ----
POSTGRES_URL=

# ---- 2. MongoDB (Atlas) ----
MONGO_URL=

# ---- 3. Cassandra (DataStax Astra) ----
ASTRA_BUNDLE_PATH=
ASTRA_CLIENT_ID=
ASTRA_CLIENT_SECRET=
ASTRA_TOKEN=
ASTRA_KEYSPACE=uber_tp

# ---- 4. Neo4j (Aura) ----
# IMPORTANTE: En AuraDB Free reciente, el NEO4J_USER es el INSTANCE ID
# (los 8 caracteres del subdominio del URI), NO la string "neo4j".
# Ej: si URI=neo4j+s://abc12345.databases.neo4j.io
#     entonces NEO4J_USER=abc12345
# Si el password fue copiado bien y la auth falla, probar con user=instance_id.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# ---- 5. Redis (Redis Cloud o Upstash) ----
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Logging ----
LOG_LEVEL=INFO

# Clave local del menu de administracion (opcional).
# Si no se define, el submenu Admin queda deshabilitado.
ADMIN_KEY=elegir-una-clave
