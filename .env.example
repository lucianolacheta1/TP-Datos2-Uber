# Plantilla del archivo .env — copialo a .env (sin .example) y completá los valores.
# El .env real NO se commitea (está en .gitignore).

# ---- 1. PostgreSQL (Neon) ----
POSTGRES_URL=

# ---- 2. MongoDB (Atlas) ----
MONGO_URL=

# ---- 3. Cassandra (DataStax Astra) ----
ASTRA_BUNDLE_PATH=
ASTRA_CLIENT_ID=
ASTRA_CLIENT_SECRET=
ASTRA_TOKEN=
ASTRA_KEYSPACE=uber_tp

# ---- 4. Neo4j (Aura) ----
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# ---- 5. Redis (Redis Cloud o Upstash) ----
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Logging ----
LOG_LEVEL=INFO
